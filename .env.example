# Groq generator API key
GROQ_API_KEY=
# Default Groq model used for generation
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini verifier API key
GEMINI_API_KEY=
# Default Gemini model used for review and validation
GEMINI_MODEL=gemini-2.5-flash

# Generator LLM provider name
GENERATOR_LLM=groq
# Verifier LLM provider name
VERIFIER_LLM=gemini

# Local Ollama endpoint for offline fallback
OLLAMA_BASE_URL=http://localhost:11434
# Local Ollama model name
OLLAMA_MODEL=mistral

# Default output directory for generated KiCad assets
KICAD_OUTPUT_DIR=./build
# Path or executable name for kicad-cli
KICAD_CLI_PATH=kicad-cli

# Logging level
LOG_LEVEL=INFO

# Minimum trace width in millimeters
DFM_MIN_TRACE_WIDTH_MM=0.2
# Minimum clearance in millimeters
DFM_MIN_CLEARANCE_MM=0.2
# Minimum via diameter in millimeters
DFM_MIN_VIA_DIAMETER_MM=0.4
# JLCPCB minimum supported trace width
JLCPCB_MIN_TRACE_WIDTH_MM=0.127

# Maximum generator-verifier correction rounds
MAX_VERIFICATION_ROUNDS=3
# Minimum acceptable confidence score
MIN_CONFIDENCE_SCORE=75
